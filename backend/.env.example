# BeeMS GED Backend Configuration

# Database path (Windows format)
# Use double backslashes for Windows paths
DATABASE_PATH=database\\beems_ged.db

# For NAS access:
# DATABASE_PATH=\\NAS\\BeeMS_GED\\database\\beems_ged.db

# Server settings
HOST=0.0.0.0
PORT=8000

# CORS settings (comma-separated)
CORS_ORIGINS=*

# Application settings
APP_NAME=BeeMS GED API
APP_VERSION=1.0.0

# Security settings
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
